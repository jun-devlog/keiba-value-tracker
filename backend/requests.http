# =============================================================================
# keiba-value-tracker API — REST Client requests
# 使い方:
#   1. サーバーを起動: .venv\Scripts\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000
#   2. 各リクエストを上から順に実行し、登録した ID を @raceId / @horseId に手動で設定する
# =============================================================================

@baseUrl       = http://localhost:8000/api/v1
@raceId        = 1
@horseId       = 2
@predictionId  = 1
@betId         = 1
@resultId      = 1


# =============================================================================
# 1. マスタ確認
# =============================================================================

### [1-1] 競馬場マスタ一覧
GET {{baseUrl}}/venues

###

### [1-2] 馬券種別マスタ一覧
GET {{baseUrl}}/bet_types

###


# =============================================================================
# 2. レース操作
# =============================================================================

### [2-1] レース登録
# レスポンスの id を @raceId に設定してください
POST {{baseUrl}}/races
Content-Type: application/json; charset=utf-8

{
  "venue_id": 1,
  "race_date": "2026-07-12",
  "race_number": 11,
  "race_name": "テストレース",
  "grade": null,
  "distance": 1600,
  "track_type": "芝"
}

###

### [2-2] レース一覧（フィルタなし）
GET {{baseUrl}}/races

###

### [2-3] レース一覧（venue_id フィルタ）
GET {{baseUrl}}/races?venue_id=1

###

### [2-4] レース一覧（race_date フィルタ）
GET {{baseUrl}}/races?race_date=2026-07-12

###

### [2-5] レース詳細
GET {{baseUrl}}/races/{{raceId}}

###

### [2-6] レース部分更新（PATCH）
PATCH {{baseUrl}}/races/{{raceId}}
Content-Type: application/json; charset=utf-8

{
  "race_name": "更新テストレース"
}

###


# =============================================================================
# 3. 出走馬操作（レースに紐付く）
# =============================================================================

### [3-1] 出走馬登録（馬番 1）
# レスポンスの id を @horseId に設定してください
POST {{baseUrl}}/races/{{raceId}}/horses
Content-Type: application/json; charset=utf-8

{
  "post_position": 1,
  "horse_name": "テスト馬A",
  "jockey": "騎手A",
  "odds": 2.1
}

###

### [3-2] 出走馬登録（馬番 2・jockey/odds 省略）
POST {{baseUrl}}/races/{{raceId}}/horses
Content-Type: application/json; charset=utf-8

{
  "post_position": 2,
  "horse_name": "テスト馬B"
}

###

### [3-3] 出走馬一覧（馬番昇順）
GET {{baseUrl}}/races/{{raceId}}/horses

###

### [3-4] 存在しない race_id → 404 確認
GET {{baseUrl}}/races/9999/horses

###


# =============================================================================
# 4. 出走馬個別操作（horse_id 指定）
# =============================================================================

### [4-1] 出走馬詳細
GET {{baseUrl}}/horses/{{horseId}}

###

### [4-2] 出走馬詳細（存在しない horse_id → 404 確認）
GET {{baseUrl}}/horses/9999

###

### [4-3] 出走馬部分更新（odds のみ変更）
PATCH {{baseUrl}}/horses/{{horseId}}
Content-Type: application/json; charset=utf-8

{
  "odds": 9.9
}

###

### [4-4] 出走馬部分更新（複数フィールド変更）
PATCH {{baseUrl}}/horses/{{horseId}}
Content-Type: application/json; charset=utf-8

{
  "horse_name": "更新馬A",
  "jockey": "更新騎手",
  "odds": 5.5
}

###

### [4-5] 出走馬部分更新（存在しない horse_id → 404 確認）
PATCH {{baseUrl}}/horses/9999
Content-Type: application/json; charset=utf-8

{
  "odds": 1.0
}

###

### [4-6] 出走馬削除
# 削除後は [4-1] を再実行して 404 になることを確認してください
DELETE {{baseUrl}}/horses/{{horseId}}

###


# =============================================================================
# 5. 予想操作（predictions）
# =============================================================================

### [5-1] 予想登録（rank=1、自信度=0.9）
# レスポンスの id を @predictionId に設定してください
POST {{baseUrl}}/races/{{raceId}}/predictions
Content-Type: application/json; charset=utf-8

{
  "horse_id": {{horseId}},
  "rank": 1,
  "confidence": 0.9,
  "memo": "本命"
}

###

### [5-2] 予想登録（rank=2、memo 省略）
# 必要に応じて horse_id を別の馬 ID に変更してください
POST {{baseUrl}}/races/{{raceId}}/predictions
Content-Type: application/json; charset=utf-8

{
  "horse_id": {{horseId}},
  "rank": 2,
  "confidence": 0.5
}

###

### [5-3] 予想一覧（rank 昇順確認）
GET {{baseUrl}}/races/{{raceId}}/predictions

###

### [5-4] 存在しない race_id → 404 確認
POST {{baseUrl}}/races/9999/predictions
Content-Type: application/json; charset=utf-8

{
  "horse_id": {{horseId}}
}

###

### [5-5] 存在しない horse_id → 404 確認
POST {{baseUrl}}/races/{{raceId}}/predictions
Content-Type: application/json; charset=utf-8

{
  "horse_id": 9999
}

###

### [5-6] horse_id が race_id に紐づかない → 400 確認
# @horseId を「別レースに登録した馬の id」に書き換えて実行してください
# 例: race_id=2 に登録された horse_id=8 を race_id=1 に対して予想しようとする
POST {{baseUrl}}/races/{{raceId}}/predictions
Content-Type: application/json; charset=utf-8

{
  "horse_id": 8
}

###

### [5-7] 予想詳細
GET {{baseUrl}}/predictions/{{predictionId}}

###

### [5-8] 予想詳細（存在しない prediction_id → 404 確認）
GET {{baseUrl}}/predictions/9999

###

### [5-9] 予想部分更新（confidence のみ変更）
PATCH {{baseUrl}}/predictions/{{predictionId}}
Content-Type: application/json; charset=utf-8

{
  "confidence": 0.75
}

###

### [5-10] 予想部分更新（memo のみ変更）
PATCH {{baseUrl}}/predictions/{{predictionId}}
Content-Type: application/json; charset=utf-8

{
  "memo": "対抗に変更"
}

###

### [5-11] 予想部分更新（存在しない prediction_id → 404 確認）
PATCH {{baseUrl}}/predictions/9999
Content-Type: application/json; charset=utf-8

{
  "confidence": 0.5
}

###

### [5-12] 予想部分更新（存在しない horse_id → 404 確認）
PATCH {{baseUrl}}/predictions/{{predictionId}}
Content-Type: application/json; charset=utf-8

{
  "horse_id": 9999
}

###

### [5-13] 予想削除
# 削除後は [5-7] を再実行して 404 になることを確認してください
DELETE {{baseUrl}}/predictions/{{predictionId}}

###

### [5-14] 予想削除（存在しない prediction_id → 404 確認）
DELETE {{baseUrl}}/predictions/9999

###


# =============================================================================
# 6. 馬券操作（bets）
# =============================================================================

### [6-1] 馬券登録（単勝）
# レスポンスの id を @betId に設定してください
POST {{baseUrl}}/races/{{raceId}}/bets
Content-Type: application/json; charset=utf-8

{
  "bet_type_id": 1,
  "amount": 1000,
  "combination": "3"
}

###

### [6-2] 馬券登録（馬連）
POST {{baseUrl}}/races/{{raceId}}/bets
Content-Type: application/json; charset=utf-8

{
  "bet_type_id": 4,
  "amount": 500,
  "combination": "2-5"
}

###

### [6-3] 馬券一覧（id 昇順確認）
GET {{baseUrl}}/races/{{raceId}}/bets

###

### [6-4] 存在しない race_id → 404 確認
GET {{baseUrl}}/races/9999/bets

###

### [6-5] 存在しない bet_type_id → 404 確認
POST {{baseUrl}}/races/{{raceId}}/bets
Content-Type: application/json; charset=utf-8

{
  "bet_type_id": 9999,
  "amount": 500,
  "combination": "1"
}

###

### [6-6] amount が 100 未満 → 422 確認
POST {{baseUrl}}/races/{{raceId}}/bets
Content-Type: application/json; charset=utf-8

{
  "bet_type_id": 1,
  "amount": 50,
  "combination": "1"
}

###

### [6-7] 馬券詳細
GET {{baseUrl}}/bets/{{betId}}

###

### [6-8] 馬券部分更新（金額と買い目を変更）
PATCH {{baseUrl}}/bets/{{betId}}
Content-Type: application/json; charset=utf-8

{
  "amount": 2000,
  "combination": "1-3"
}

###

### [6-9] 馬券部分更新（存在しない bet_type_id → 404 確認）
PATCH {{baseUrl}}/bets/{{betId}}
Content-Type: application/json; charset=utf-8

{
  "bet_type_id": 9999
}

###

### [6-10] 馬券部分更新（amount が 100 未満 → 422 確認）
PATCH {{baseUrl}}/bets/{{betId}}
Content-Type: application/json; charset=utf-8

{
  "amount": 50
}

###

### [6-11] 馬券削除
DELETE {{baseUrl}}/bets/{{betId}}

###

### [6-12] 馬券詳細（削除後 → 404 確認）
GET {{baseUrl}}/bets/{{betId}}

###


# =============================================================================
# 7. レース結果操作（results）
# =============================================================================

### [7-1] レース結果登録
# レスポンスの id を @resultId に設定してください
POST {{baseUrl}}/races/{{raceId}}/result
Content-Type: application/json; charset=utf-8

{
  "order_of_finish": "3-5-2",
  "total_return": 1800
}

###

### [7-2] 既に存在する race_id への登録 → 400 確認
POST {{baseUrl}}/races/{{raceId}}/result
Content-Type: application/json; charset=utf-8

{
  "total_return": 2000
}

###

### [7-3] レース結果取得
# 事前に馬券（bets）が登録されていれば total_bet / profit / roi が計算される
GET {{baseUrl}}/races/{{raceId}}/result

###

### [7-4] 存在しない race_id への結果取得 → 404 確認
GET {{baseUrl}}/races/9999/result

###

### [7-5] 存在しない race_id への結果登録 → 404 確認
POST {{baseUrl}}/races/9999/result
Content-Type: application/json; charset=utf-8

{
  "total_return": 0
}

###

### [7-6] レース結果部分更新
PATCH {{baseUrl}}/results/{{resultId}}
Content-Type: application/json; charset=utf-8

{
  "order_of_finish": "3-5-2-1",
  "total_return": 2500
}

###

### [7-7] レース結果部分更新（total_return=0）
PATCH {{baseUrl}}/results/{{resultId}}
Content-Type: application/json; charset=utf-8

{
  "total_return": 0
}

###

### [7-8] レース結果部分更新（total_return=-1 → 422 確認）
PATCH {{baseUrl}}/results/{{resultId}}
Content-Type: application/json; charset=utf-8

{
  "total_return": -1
}

###

### [7-9] レース結果削除
DELETE {{baseUrl}}/results/{{resultId}}

###

### [7-10] 削除後 GET /races/{race_id}/result → 404 確認
GET {{baseUrl}}/races/{{raceId}}/result

###


# =============================================================================
# 8. 収支統計（stats）
# =============================================================================

### [8-1] 収支サマリー取得
GET {{baseUrl}}/stats/summary

###

### [8-2] 馬券種別ごとの収支サマリー取得
# ※ 注意: MVP暫定仕様として、by-bet-type の total_return は常に 0 が返ります。
# 正確な券種別回収率は、将来的に result_returns を実装した後に対応する方針です。
GET {{baseUrl}}/stats/by-bet-type

###





# =============================================================================
# 9. デバッグ・データ修復
# =============================================================================

### [9-1] 文字化けデータ修復用（race_name, track_type）
# ※ 自分の環境で化けているレースのIDを @raceId に指定して実行してください
PATCH {{baseUrl}}/races/{{raceId}}
Content-Type: application/json; charset=utf-8

{
  "race_name": "テストレース（修復済）",
  "track_type": "芝"
}

###
